{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Preview",
      "runtimeExecutable": "py",
      "runtimeArgs": ["-m", "http.server", "8888", "--directory", "preview"],
      "port": 8888
    },
    {
      "name": "Flask + MySQL (Docker Compose)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build", "web"],
      "port": 5000
    },
    {
      "name": "Flask App (Python directo)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["maquinas-medellin-frontend/app.py"],
      "port": 5000
    }
  ]
}
