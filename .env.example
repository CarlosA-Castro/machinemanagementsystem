# ============================================================
# TEMPLATE DE VARIABLES DE ENTORNO
# Copiar a .env y completar con valores reales.
# El archivo .env NUNCA se sube al repositorio.
# ============================================================

# MySQL
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Contraseña que usa Flask para conectarse (generalmente = MYSQL_PASSWORD)
DB_PASSWORD=

# Flask secret key — generar con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Alertas WhatsApp (CallMeBot — https://www.callmebot.com/)
ALERT_PHONE=
CALLMEBOT_APIKEY=

# Alertas Email (Gmail App Password — no la contraseña de la cuenta)
ALERT_EMAIL_FROM=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_TO=
